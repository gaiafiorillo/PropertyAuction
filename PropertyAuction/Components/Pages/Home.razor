@rendermode InteractiveServer
@page "/"
@using PropertyAuction.Core.Models
@using PropertyAuction.Services.Services
@inject AuctionService AuctionService
@inject BidService BidService
@implements IDisposable


<PageTitle>Property Auction Platform</PageTitle>

<!-- Bid Modal Overlay -->
@if (showBidModal && selectedAuction != null)
{
    <div class="modal-overlay" @onclick="CloseBidModal">
        <div class="modal-card" @onclick:stopPropagation="true">

            <div class="modal-header">
                <div>
                    <p class="modal-subtitle">Placing bid on</p>
                    <h3 class="modal-title">@selectedAuction.Title</h3>
                </div>
                <button class="modal-close" @onclick="CloseBidModal">&#x2715;</button>
            </div>

            <div class="modal-stats">
                <div class="modal-stat">
                    <span class="stat-label">Current highest bid</span>
                    <span class="stat-value">£@selectedAuction.CurrentHighestBid.ToString("N0")</span>
                </div>
                <div class="modal-stat">
                    <span class="stat-label">Total bids</span>
                    <span class="stat-value">@GetBidCount(selectedAuction.AuctionId) bids</span>
                </div>
            </div>

            <div class="modal-input-group">
                <label class="modal-label">Your bid amount (£)</label>
                <div class="modal-input-wrapper">
                    <span class="modal-currency">£</span>
                    <input type="number"
                           class="modal-input"
                           placeholder="@((selectedAuction.CurrentHighestBid + 1000).ToString("N0"))"
                           @bind="bidAmount"
                           @bind:event="oninput" />
                </div>
                <p class="modal-hint">Must be higher than £@selectedAuction.CurrentHighestBid.ToString("N0")</p>
            </div>

            @if (!string.IsNullOrEmpty(bidMessage))
            {
                <div class="modal-message @(bidSuccess ? "modal-message--success" : "modal-message--error")">
                    @bidMessage
                </div>
            }

            <div class="modal-actions">
                <button class="modal-btn modal-btn--cancel" @onclick="CloseBidModal">Cancel</button>
                <button class="modal-btn modal-btn--confirm" @onclick="ConfirmBid" disabled="@isSubmitting">
                    @(isSubmitting ? "Placing..." : "Confirm bid")
                </button>
            </div>

        </div>
    </div>
}

<!-- Header -->
<div class="site-header">
    <button class="icon-btn" @onclick="NavigateHome">
        <span class="icon">🏠</span>
    </button>
    <h1 class="site-title">Property Auction</h1>
    <a href="/submit" class="header-link">Sell properties for organisations</a>
    <button class="icon-btn" @onclick="NavigateToProfile">
        <span class="icon">👤</span>
    </button>
    
</div>

<!-- Filter Search Section -->
<div class="filter-section">
    <h2>Filter search</h2>
    <div class="filter-container">
        <div class="filter-item">
            <label>Location</label>
            <select @bind="selectedLocation" class="filter-input">
                <option value="">All Locations</option>
                <option value="London">London</option>
                <option value="Manchester">Manchester</option>
                <option value="Birmingham">Birmingham</option>
            </select>
        </div>
        <div class="filter-item">
            <label>Property type</label>
            <select @bind="selectedCategory" class="filter-input">
                <option value="">All Types</option>
                <option value="houses">Houses</option>
                <option value="flats">Flats</option>
                <option value="shops">Shops</option>
            </select>
        </div>
        <div class="filter-item">
            <label>Min price</label>
            <input type="number" @bind="minPrice" placeholder="5000" class="filter-input" />
        </div>
        <div class="filter-item">
            <label>Max price</label>
            <input type="number" @bind="maxPrice" placeholder="1000000" class="filter-input" />
        </div>
        <button class="update-btn" @onclick="UpdatePreferences">Update preferences</button>
    </div>
</div>

<!-- Properties Section -->
<div class="properties-section">
    <h2>Properties for auction (@filteredAuctions.Count)</h2>

    @if (!filteredAuctions.Any())
    {
        <div class="empty-state">
            <p>No properties found matching your criteria.</p>
            <button class="update-btn" @onclick="ClearFilters">Clear filters</button>
        </div>
    }
    else
    {
        <div class="property-grid">
            @foreach (var auction in filteredAuctions)
            {
                <div class="property-card">
                    <div class="property-image-placeholder">
                        <span class="image-icon">🏠</span>
                        <p>@auction.Category</p>
                    </div>
                    <div class="card-header">
                        <div class="property-info">
                            <h3 class="property-title">@auction.Title</h3>
                            <p class="property-location">📍 @auction.Location</p>
                        </div>
                        <button class="bookmark-btn" @onclick="() => ToggleBookmark(auction.AuctionId)">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                            </svg>
                        </button>
                    </div>
                    <p class="property-description">@auction.Description</p>
                    <div class="property-details">
                        <div class="price-section">
                            <span class="current-bid-label">Current Bid</span>
                            <p class="property-price">£@auction.CurrentHighestBid.ToString("N0")</p>
                            <span class="bid-count">@GetBidCount(auction.AuctionId) bids</span>
                        </div>
                        <div class="time-left">
                            <span class="time-left-label">Time left</span>
                            <p class="time-remaining">@GetTimeRemaining(auction.EndTime)</p>
                        </div>
                    </div>
                    @if (auction.IsActive())
                    {
                        <button class="bid-btn" @onclick="() => OpenBidModal(auction)">
                            Place Bid
                        </button>
                    }
                    else
                    {
                        <button class="bid-btn" disabled style="background:#bdc3c7; cursor:not-allowed;">
                            Auction Ended
                        </button>
                    }
                </div>
            }
        </div>
    }
</div>

<!-- Footer -->
<footer class="site-footer">
    <div class="footer-content">
        <div class="footer-section">
            <h3>About</h3>
            <a href="/about">About Us</a>
            <a href="/terms">Terms & Conditions</a>
        </div>
        <div class="footer-section">
            <h3>Contact</h3>
            <a href="/contact">Contact Us</a>
        </div>
    </div>
</footer>

@code {
    
    
    

    // ── Modal state ───────────────────────────────────────────────
    private bool showBidModal = false;
    private Auction? selectedAuction = null;
    private decimal? bidAmount = null;
    private string bidMessage = "";
    private bool bidSuccess = false;
    private bool isSubmitting = false;

    private void OpenBidModal(Auction auction)
    {
        selectedAuction = auction;
        bidAmount = null;
        bidMessage = "";
        bidSuccess = false;
        showBidModal = true;
    }

    private void CloseBidModal()
    {
        showBidModal = false;
        selectedAuction = null;
        bidMessage = "";
    }

    private void ConfirmBid()
    {
        if (selectedAuction == null) return;

        if (bidAmount == null || bidAmount <= 0)
        {
            bidMessage = "Please enter a bid amount.";
            bidSuccess = false;
            return;
        }

        isSubmitting = true;

        // TODO: replace hardcoded bidderId with real session user ID once login is implemented
        int bidderId = 1;

        var (success, message) = BidService.PlaceBid(selectedAuction.AuctionId, bidderId, bidAmount.Value);

        bidMessage = message;
        bidSuccess = success;
        isSubmitting = false;

        if (success)
        {
            // Refresh the card's displayed bid count and price
            StateHasChanged();
        }
    }


    private int GetBidCount(int auctionId) => BidService.GetBidCount(auctionId);

    private List<Auction> allAuctions = new();
    private List<Auction> filteredAuctions = new();
    private string selectedLocation = "";
    private string selectedCategory = "";
    private decimal? minPrice;
    private decimal? maxPrice;

    private System.Threading.Timer? _timer;

    //bid timer
    protected override void OnInitialized()
    {
        allAuctions = AuctionService.GetActive();
        filteredAuctions = allAuctions;

        // Tick every second to update countdowns
        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                filteredAuctions = allAuctions.Where(a =>
                    a.Status == AuctionStatus.Active).ToList();
                StateHasChanged();
            });
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
    private void UpdatePreferences()
    {
        filteredAuctions = allAuctions;

        if (!string.IsNullOrEmpty(selectedLocation))
            filteredAuctions = filteredAuctions.Where(a => a.Location == selectedLocation).ToList();

        if (!string.IsNullOrEmpty(selectedCategory))
            filteredAuctions = filteredAuctions.Where(a => a.Category == selectedCategory).ToList();

        if (minPrice.HasValue)
            filteredAuctions = filteredAuctions.Where(a => a.CurrentHighestBid >= minPrice.Value).ToList();

        if (maxPrice.HasValue)
            filteredAuctions = filteredAuctions.Where(a => a.CurrentHighestBid <= maxPrice.Value).ToList();

        StateHasChanged();
    }

    private void ClearFilters()
    {
        selectedLocation = "";
        selectedCategory = "";
        minPrice = null;
        maxPrice = null;
        filteredAuctions = allAuctions;
    }

    private string GetTimeRemaining(DateTime endTime)
    {
        var timeLeft = endTime - DateTime.Now;
        if (timeLeft.TotalSeconds <= 0) return "Ended";
        if (timeLeft.TotalDays >= 1) return $"{(int)timeLeft.TotalDays}d {timeLeft.Hours}h {timeLeft.Minutes}m";
        return $"{timeLeft.Hours}h {timeLeft.Minutes}m";
    }

    private void NavigateHome() { }
    private void NavigateToProfile() { }
    private void ToggleBookmark(int auctionId) { }
}