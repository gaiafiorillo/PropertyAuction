@rendermode InteractiveServer
@page "/"
@using PropertyAuction.Core.Models
@using PropertyAuction.Services.Services
@using PropertyAuction.Components.Shared
@inject AuctionService AuctionService
@inject BidService BidService
@implements IDisposable

<PageTitle>MainsAuction</PageTitle>

<BidModal Auction="selectedAuction"
          IsVisible="showBidModal"
          OnClose="CloseBidModal"
          OnBidPlaced="StateHasChanged" />

<!-- Header -->
<div class="site-header">
    <button class="icon-btn" @onclick="NavigateHome">
        <div class="logo-mark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
        </div>
    </button>
    <h1 class="site-title">MainsAuction</h1>
    <a href="/submit" class="header-link">Sell a property</a>
    <a href="/about" class="header-link">How it works</a>
    <div class="header-divider"></div>
    <button class="sign-in-btn" @onclick="NavigateToProfile">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
        </svg>
        Sign in
    </button>
</div>

<!-- Hero Filter Section -->
<div class="filter-section">
    <div class="filter-bg"></div>
    <div class="filter-overlay"></div>
    <div class="filter-decor-1"></div>
    <div class="filter-decor-2"></div>

    <div class="hero-stat-pills">
        <div class="hero-stat-pill">@allAuctions.Count active auctions</div>
        <div class="hero-stat-pill">England </div>
    </div>

    <div class="filter-inner">
        <div class="hero-text-backdrop">
            <div class="hero-live-badge">
                <div class="hero-live-dot"></div>
                <span class="hero-live-text">@allAuctions.Count live auctions</span>
            </div>
            <h2 class="filter-hero-heading">Find your next <span>property</span> at auction</h2>
            <p class="filter-hero-sub">Browse hundreds of residential and commercial properties across England and Wales</p>
        </div>

        <div class="filter-card">
            <div class="filter-container">
                <div class="filter-item">
                    <label>Location</label>
                    <select @bind="stagingLocation" class="filter-input">
                        <option value="">All Locations</option>
                        <option value="London">London</option>
                        <option value="Manchester">Manchester</option>
                        <option value="Birmingham">Birmingham</option>
                    </select>
                </div>
                <div class="filter-item">
                    <label>Property type</label>
                    <select @bind="stagingCategory" class="filter-input">
                        <option value="">All Types</option>
                        <option value="houses">Houses</option>
                        <option value="flats">Flats</option>
                        <option value="shops">Shops</option>
                    </select>
                </div>
                <div class="filter-item">
                    <label>Min bedrooms</label>
                    <select @bind="stagingMinBedrooms" class="filter-input">
                        <option value="0">No min</option>
                        <option value="1">1+</option>
                        <option value="2">2+</option>
                        <option value="3">3+</option>
                        <option value="4">4+</option>
                    </select>
                </div>
                <div class="filter-item">
                    <label>Max price</label>
                    <select @bind="stagingMaxPrice" class="filter-input">
                        <option value="">Any price</option>
                        <option value="100000">£100,000</option>
                        <option value="200000">£200,000</option>
                        <option value="300000">£300,000</option>
                        <option value="500000">£500,000</option>
                        <option value="750000">£750,000</option>
                        <option value="1000000">£1,000,000</option>
                        <option value="custom">Custom...</option>
                    </select>
                    @if (stagingMaxPrice == "custom")
                    {
                        <input type="number"
                               @bind="stagingCustomMaxPrice"
                               placeholder="Enter amount"
                               class="filter-input"
                               style="margin-top: 8px;" />
                    }
                </div>
                <button class="update-btn" @onclick="UpdatePreferences">Search</button>
                <button class="clear-btn" @onclick="ClearFilters">Clear</button>
            </div>
        </div>
    </div>
</div>

<!-- Trust Bar -->
<div class="trust-bar">
    <div class="trust-bar-inner">
        <div class="trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Secure bidding
        </div>
        <div class="trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
            </svg>
            Live countdown timers
        </div>
        <div class="trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
            Admin approved listings
        </div>
        <div class="trust-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
            England regulated
        </div>
    </div>
</div>

<!-- Properties Section -->
<div class="properties-section">
    <div class="listings-heading-row">
        <h2>Properties for auction <span class="listings-count">(@filteredAuctions.Count)</span></h2>
    </div>

    @if (!filteredAuctions.Any())
    {
        <div class="empty-state">
            <p>No properties found matching your criteria.</p>
            <button class="update-btn" @onclick="ClearFilters">Clear filters</button>
        </div>
    }
    else
    {
        <div class="property-grid">
            @foreach (var auction in filteredAuctions)
            {
                <div class="property-card">

                    <a href="/auction/@auction.AuctionId" class="detail-link">
                        <div class="card-image-wrapper">
                            @if (!string.IsNullOrEmpty(auction.ImageUrl))
                            {
                                <img src="@auction.ImageUrl" class="property-image" alt="@auction.Title"/>
                            }
                            else
                            {
                                <div class="property-image-placeholder">
                                    <span class="image-icon">🏠</span>
                                    <p>@auction.Category</p>
                                </div>
                            }
                            <div class="card-type-badge">@auction.Category</div>
                            <div class="card-time-badge @(auction.IsActive() ? "" : "ended")">
                                @(auction.IsActive() ? GetTimeRemaining(auction.EndTime) : "Ended")
                            </div>
                        </div>
                    </a>

                    <div class="card-header">
                        <div class="property-info">
                            <h3 class="property-title">
                                <a href="/auction/@auction.AuctionId" class="detail-link">@auction.Title</a>
                            </h3>
                            <p class="property-location">📍 @auction.Location</p>
                        </div>
                        <button class="bookmark-btn @(bookmarked.Contains(auction.AuctionId) ? "bookmarked" : "")"
                                @onclick="() => ToggleBookmark(auction.AuctionId)">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                            </svg>
                        </button>
                    </div>
                    <p class="property-description">@auction.Description</p>
                    @if (auction.Bedrooms > 0 || auction.Bathrooms > 0)
                    {
                        <div class="property-features">
                            @if (auction.Bedrooms > 0)
                            {
                                <span class="feature-badge">🛏 @auction.Bedrooms bed</span>
                            }
                            @if (auction.Bathrooms > 0)
                            {
                                <span class="feature-badge">🚿 @auction.Bathrooms bath</span>
                            }
                        </div>
                    }
                    <div class="property-details">
                        <div class="price-section">
                            <span class="current-bid-label">Current Bid</span>
                            <p class="property-price">£@auction.CurrentHighestBid.ToString("N0")</p>
                            <span class="bid-count">@GetBidCount(auction.AuctionId) bids</span>
                        </div>
                        <div class="time-left">
                            <span class="time-left-label">Time left</span>
                            <p class="time-remaining">@GetTimeRemaining(auction.EndTime)</p>
                        </div>
                    </div>
                    @if (auction.IsActive())
                    {
                        <button class="bid-btn" @onclick="() => OpenBidModal(auction)">
                            Place Bid
                        </button>
                    }
                    else
                    {
                        <button class="bid-btn" disabled>
                            Auction Ended
                        </button>
                    }
                </div>
            }
        </div>
    }
</div>

<!-- Footer -->
<footer class="site-footer">
    <div class="footer-content">
        <div class="footer-section">
            <h3>About</h3>
            <a href="/about">About Us</a>
            <a href="/terms">Terms &amp; Conditions</a>
        </div>
        <div class="footer-section">
            <h3>Contact</h3>
            <a href="/contact">Contact Us</a>
        </div>
    </div>
    <ChatAgent Floating="true" />
</footer>

@code {
    private bool showBidModal = false;
    private Auction? selectedAuction = null;
    private HashSet<int> bookmarked = new();

    private void OpenBidModal(Auction auction)
    {
        selectedAuction = auction;
        showBidModal = true;
    }

    private void CloseBidModal()
    {
        showBidModal = false;
        selectedAuction = null;
    }

    private int GetBidCount(int auctionId) => BidService.GetBidCount(auctionId);

    // Staging variables (held until Search is clicked)
    private string stagingLocation = "";
    private string stagingCategory = "";
    private int stagingMinBedrooms = 0;
    private string stagingMaxPrice = "";
    private decimal? stagingCustomMaxPrice = null;

    // Applied variables
    private string selectedLocation = "";
    private string selectedCategory = "";
    private int minBedrooms = 0;
    private decimal? maxPrice;
    private string selectedMaxPrice = "";
    private decimal? customMaxPrice = null;

    private List<Auction> allAuctions = new();
    private List<Auction> filteredAuctions = new();
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        allAuctions = AuctionService.GetActive();
        filteredAuctions = allAuctions;

        _timer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                allAuctions = AuctionService.GetActive();
                ApplyFilters();
                StateHasChanged();
            });
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    public void Dispose() => _timer?.Dispose();

    private void ApplyFilters()
    {
        filteredAuctions = allAuctions;

        if (!string.IsNullOrEmpty(selectedLocation))
            filteredAuctions = filteredAuctions.Where(a => a.Location == selectedLocation).ToList();

        if (!string.IsNullOrEmpty(selectedCategory))
            filteredAuctions = filteredAuctions.Where(a => a.Category == selectedCategory).ToList();

        if (minBedrooms > 0)
            filteredAuctions = filteredAuctions.Where(a => a.Bedrooms >= minBedrooms).ToList();

        if (maxPrice.HasValue)
            filteredAuctions = filteredAuctions.Where(a => a.CurrentHighestBid <= maxPrice.Value).ToList();
    }

    private void UpdatePreferences()
    {
        selectedLocation = stagingLocation;
        selectedCategory = stagingCategory;
        minBedrooms = stagingMinBedrooms;
        selectedMaxPrice = stagingMaxPrice;
        customMaxPrice = stagingCustomMaxPrice;

        if (selectedMaxPrice == "custom")
            maxPrice = customMaxPrice;
        else if (string.IsNullOrEmpty(selectedMaxPrice))
            maxPrice = null;
        else
            maxPrice = decimal.Parse(selectedMaxPrice);

        ApplyFilters();
        StateHasChanged();
    }

    private void ClearFilters()
    {
        stagingLocation = "";
        stagingCategory = "";
        stagingMinBedrooms = 0;
        stagingMaxPrice = "";
        stagingCustomMaxPrice = null;
        selectedLocation = "";
        selectedCategory = "";
        minBedrooms = 0;
        maxPrice = null;
        selectedMaxPrice = "";
        customMaxPrice = null;
        ApplyFilters();
    }

    private string GetTimeRemaining(DateTime endTime)
    {
        var timeLeft = endTime - DateTime.Now;
        if (timeLeft.TotalSeconds <= 0) return "Ended";
        if (timeLeft.TotalDays >= 1) return $"{(int)timeLeft.TotalDays}d {timeLeft.Hours}h {timeLeft.Minutes}m {timeLeft.Seconds}s";
        return $"{timeLeft.Hours}h {timeLeft.Minutes}m {timeLeft.Seconds}s";
    }

    private void NavigateHome() { }
    private void NavigateToProfile() { }

    private void ToggleBookmark(int auctionId)
    {
        if (bookmarked.Contains(auctionId))
            bookmarked.Remove(auctionId);
        else
            bookmarked.Add(auctionId);
    }
}