@rendermode InteractiveServer
@page "/login"
@using PropertyAuction.Core.Interfaces
@inject IUserService UserService
@inject NavigationManager Navigation

<div class="site-header">
    <h1> Property Auction </h1>
</div>

<div class="detail-container">
    <h2 id="login-title"> Log into your account</h2>

    <p class="detail-box">
        Email:
        <input type="text" @bind="UsernameOrEmail" placeholder="Enter your email"><br>

        Password:
        <input type="password" @bind="Password" placeholder="Enter your password"><br>

        <button @onclick="HandleLogin">Login</button>

        @if (!string.IsNullOrEmpty(Feedback))
        {
            <p>@Feedback</p>
        }
    </p>

    <h4 class="divider">or</h4>

    <button class="newAccbtn" @onclick='() => Navigation.NavigateTo("/register")'>
        Create an account
    </button>
</div>

<footer class="site-footer">
    <div class="footer-content">
        <div class="footer-section">
            <h3>About</h3>
            <a href="/about">About Us</a>
            <a href="/terms">Terms & Conditions</a>
        </div>
        <div class="footer-section">
            <h3>Contact</h3>
            <a href="/contact">Contact Us</a>
        </div>
    </div>
</footer>

@code {
    public string UsernameOrEmail { get; set; } = string.Empty;
    public string Password { get; set; } = string.Empty;
    public string Feedback { get; set; } = string.Empty;

    private async Task HandleLogin()
    {
        var user = await UserService.LoginAsync(UsernameOrEmail, Password);

        if (user == null)
        {
            Feedback = "Invalid email or password";
            return;
        }

        // Login succeeded but requires 2FA
        Navigation.NavigateTo("/verify?type=login");
    }
}