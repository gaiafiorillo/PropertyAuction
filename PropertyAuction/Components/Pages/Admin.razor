@rendermode InteractiveServer
@page "/admin"
@using PropertyAuction.Core.Models
@using PropertyAuction.Services.Services
@inject AdminService AdminService
@inject NavigationManager Navigation

<PageTitle>Admin Panel - MainsAuction</PageTitle>

@using PropertyAuction.Components.Shared

<SiteHeader />

<div class="admin-container">
    <h1>Admin Panel - Pending Auctions</h1>
    
    @if (pendingAuctions.Count == 0)
    {
        <div class="empty-state">
            <p>No pending auctions to review.</p>
            <p>Submissions will appear here for approval.</p>
        </div>
    }
    else
    {
        <p class="pending-count">@pendingAuctions.Count auction(s) awaiting approval</p>
        
        <div class="admin-grid">
            @foreach (var auction in pendingAuctions)
            {
                <div class="admin-card">
                    <div class="admin-card-header">
                        <h3>@auction.Title</h3>
                        <span class="status-badge pending">Pending</span>
                    </div>
                    
                    <div class="admin-card-body">
                        <p><strong>Location:</strong> @auction.Location</p>
                        <p><strong>Category:</strong> @auction.Category</p>
                        <p><strong>Starting Price:</strong> £@auction.StartingPrice.ToString("N0")</p>
                        <p><strong>Description:</strong> @auction.Description</p>
                        <p><strong>Submitted for:</strong> @auction.StartTime.ToString("dd MMM yyyy") - @auction.EndTime.ToString("dd MMM yyyy")</p>
                    </div>
                    
                    <div class="admin-actions">
                        <button class="btn-approve" @onclick="() => Approve(auction.AuctionId)">
                            ✓ Approve & Publish
                        </button>
                        <button class="btn-reject" @onclick="() => Reject(auction.AuctionId)">
                            ✗ Reject
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="@(messageSuccess ? "success-message" : "error-message")">
            @message
        </div>
    }
</div>

@code {
    private List<Auction> pendingAuctions = new();
    private string message = "";
    private bool messageSuccess = false;
    
    protected override void OnInitialized()
    {
        Console.WriteLine("Admin page loading...");
        LoadPending();
        Console.WriteLine($"Found {pendingAuctions.Count} pending auctions");
    }
    
    private void LoadPending()
    {
        pendingAuctions = AdminService.GetPendingAuctions();
        Console.WriteLine($"LoadPending: {pendingAuctions.Count} pending auctions");
        foreach (var a in pendingAuctions)
        {
            Console.WriteLine($"  - Auction #{a.AuctionId}: {a.Title} (Status: {a.Status})");
        }
    }
    
    private void Approve(int auctionId)
    {
        Console.WriteLine($"Approving auction #{auctionId}");
        if (AdminService.ApproveAuction(auctionId))
        {
            message = "Auction approved and published!";
            messageSuccess = true;
            LoadPending();
            
            Task.Delay(3000).ContinueWith(_ => 
            {
                InvokeAsync(() => { message = ""; StateHasChanged(); });
            });
        }
    }
    
    private void Reject(int auctionId)
    {
        Console.WriteLine($"Rejecting auction #{auctionId}");
        if (AdminService.RejectAuction(auctionId))
        {
            message = "Auction rejected.";
            messageSuccess = false;
            LoadPending();
            
            Task.Delay(3000).ContinueWith(_ => 
            {
                InvokeAsync(() => { message = ""; StateHasChanged(); });
            });
        }
    }
}